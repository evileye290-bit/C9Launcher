<Window x:Class="C9Launcher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="C9 Online Launcher"
        Height="640" 
        Width="1024"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Window.Resources>
        <Style x:Key="StartButtonStyle" TargetType="Button">
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#FFFFB700" Offset="0"/>
                        <GradientStop Color="#FFFF7A00" Offset="1"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Black"/>
            <Setter Property="FontSize" Value="24"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" BorderThickness="2" BorderBrush="#FFFFE082">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#FFFFD54F" Offset="0"/>
                                            <GradientStop Color="#FFFF8F00" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#FF555555"/>
                                <Setter Property="Foreground" Value="#FFAAAAAA"/>
                                <Setter Property="BorderBrush" Value="#FF444444"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GlassButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#66000000"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4" BorderThickness="1" BorderBrush="#66FFFFFF">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#99000000"/>
                                <Setter Property="BorderBrush" Value="#AAFFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border CornerRadius="10" Background="#FF0A0A0A" ClipToBounds="True" BorderThickness="1" BorderBrush="#44FFFFFF">
        <Grid>
            <Image Name="BannerImage" Source="Banners/bg.png" Stretch="Fill" HorizontalAlignment="Center" VerticalAlignment="Center"/>

            <Border>
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#B2000000" Offset="0"/>
                        <GradientStop Color="Transparent" Offset="0.25"/>
                        <GradientStop Color="#E6000000" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
            </Border>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,15,15,0">
                <Button Content="—" Width="35" Height="30" Click="BtnMinimize_Click" Style="{StaticResource GlassButtonStyle}" Margin="0,0,8,0" FontSize="12"/>
                <Button Content="✕" Width="35" Height="30" Click="BtnClose_Click" Style="{StaticResource GlassButtonStyle}" Foreground="#FFFF5555" FontSize="14" FontWeight="Bold"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="35,25,0,0">
                <Image Source="/Banners/logo/logo.png" Width="150" Height="80" Stretch="Uniform">
                    <Image.Effect>
                        <DropShadowEffect Color="Black" BlurRadius="10" ShadowDepth="3" Opacity="0.8"/>
                    </Image.Effect>
                </Image>

                <TextBlock Text="C9HD-2026" Foreground="#FFDDDDDD" FontSize="40" FontWeight="Bold" VerticalAlignment="Center" Margin="20,0,0,0">
                    <TextBlock.Effect>
                        <DropShadowEffect Color="Black" BlurRadius="5" ShadowDepth="2" Opacity="0.9"/>
                    </TextBlock.Effect>
                </TextBlock>
            </StackPanel>

            <Border x:Name="NewsCard" Width="940" Height="400" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,110,0,0"
                    Background="#B2000000" CornerRadius="10" BorderBrush="#55FFFFFF" BorderThickness="1"
                    MouseLeftButtonUp="NewsCard_MouseLeftButtonUp" MouseLeftButtonDown="NewsCard_MouseLeftButtonDown" Cursor="Hand">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="450"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border CornerRadius="9,0,0,9" ClipToBounds="True" Background="#FF080808">
                        <Image x:Name="NewsImage" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>

                    <Border HorizontalAlignment="Left" VerticalAlignment="Top" Margin="15,15,0,0" Background="#FFE74C1A" CornerRadius="4" Padding="12,6">
                        <TextBlock x:Name="TxtNewsCategory" Text="NEWS" Foreground="White" FontWeight="Bold" FontSize="14"/>
                    </Border>

                    <StackPanel Grid.Column="1" Margin="35,30,35,30">
                        <TextBlock x:Name="TxtNewsTitle" Foreground="White" FontWeight="Bold" FontSize="26" TextWrapping="Wrap" Margin="0,0,0,15" MaxHeight="70" TextTrimming="CharacterEllipsis"/>
                        <TextBlock x:Name="TxtNewsDate" Foreground="#FFBDBDBD" FontSize="14" Margin="0,0,0,15"/>
                        <TextBlock x:Name="TxtNewsSummary" Foreground="#FFDDDDDD" FontSize="16" TextWrapping="Wrap" Margin="0,0,0,20" MaxHeight="160" TextTrimming="CharacterEllipsis" LineHeight="24"/>

                        <TextBlock Text="Read More ▸" Foreground="#FFFFB700" FontWeight="Bold" FontSize="16" Margin="0,10,0,0"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,35,30">
                        <TextBlock x:Name="TxtNewsIndex" Foreground="#FFAAAAAA" FontSize="14" VerticalAlignment="Center" Margin="0,0,20,0"/>
                        <Button x:Name="BtnPrevNews" Content="◀" Width="40" Height="35" Click="BtnPrevNews_Click" Style="{StaticResource GlassButtonStyle}" Margin="0,0,10,0" FontSize="14"/>
                        <Button x:Name="BtnNextNews" Content="▶" Width="40" Height="35" Click="BtnNextNews_Click" Style="{StaticResource GlassButtonStyle}" FontSize="14"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid VerticalAlignment="Bottom" Height="90" Margin="35,0,35,25">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="FB" Width="50" Height="45" Click="BtnSocial_Click" Tag="https://www.facebook.com/people/C9HD/61583671481490/" Style="{StaticResource GlassButtonStyle}" Margin="0,0,12,0"/>
                    <Button Content="DC" Width="50" Height="45" Click="BtnSocial_Click" Tag="https://discord.com/invite/yourserver" Style="{StaticResource GlassButtonStyle}" Margin="0,0,12,0"/>
                    <Button Content="WEB" Width="60" Height="45" Click="BtnSocial_Click" Tag="https://c9-hd.com/" Style="{StaticResource GlassButtonStyle}"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Vertical" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="20,0,20,0">
                    <TextBlock Name="TxtVersion" Text="Version: ตรวจสอบ..." Foreground="#FFEEEEEE" HorizontalAlignment="Center" FontSize="14" Margin="0,0,0,10"/>
                    <Grid Width="380">
                        <ProgressBar Name="UpdateProgressBar" Height="8" Minimum="0" Maximum="100" Visibility="Hidden" BorderThickness="0" Background="#44FFFFFF" Foreground="#FFFFB700"/>
                        <TextBlock Name="TxtProgress" Text="0%" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="12" FontWeight="Bold" Visibility="Hidden" Margin="0,-25,0,0">
                            <TextBlock.Effect>
                                <DropShadowEffect Color="Black" BlurRadius="4" ShadowDepth="2"/>
                            </TextBlock.Effect>
                        </TextBlock>
                    </Grid>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Name="BtnOption" Content="⚙ Setting" Width="90" Height="45" Click="BtnOption_Click" Style="{StaticResource GlassButtonStyle}" Margin="0,0,12,0"/>
                    <Button Name="BtnRepair" Content="⟳ Repair" Width="90" Height="45" Click="BtnRepair_Click" Style="{StaticResource GlassButtonStyle}" Margin="0,0,20,0"/>
                    <Button Name="BtnStart" Content="START GAME" Width="220" Height="65" Click="BtnStart_Click" Style="{StaticResource StartButtonStyle}"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>