<Window x:Class="C9Launcher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="C9 Online Launcher"
        Height="500"
        Width="800"
        WindowStartupLocation="CenterScreen"
        Background="#FF1E1E1E"
        ResizeMode="CanMinimize">
    <Grid>
        <Image Name="BannerImage"
               Stretch="UniformToFill"
               Margin="0,0,0,80"/>

        <Border x:Name="NewsCard"
                Width="360"
                Height="365"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                Margin="20,20,0,0"
                Background="#CC0E0E0E"
                CornerRadius="10"
                BorderBrush="#55F2B300"
                BorderThickness="1"
                MouseLeftButtonUp="NewsCard_MouseLeftButtonUp"
                Cursor="Hand">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="210"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid>
                    <Image x:Name="NewsImage"
                           Stretch="UniformToFill"/>

                    <Border HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            Margin="0,12,12,0"
                            Background="#FFE74C1A"
                            CornerRadius="4"
                            Padding="10,4">
                        <TextBlock x:Name="TxtNewsCategory"
                                   Text="NEWS"
                                   Foreground="White"
                                   FontWeight="Bold"
                                   FontSize="12"/>
                    </Border>
                </Grid>

                <StackPanel Grid.Row="1" Margin="18,14,18,12">
                    <TextBlock x:Name="TxtNewsTitle"
                               Foreground="White"
                               FontWeight="Bold"
                               FontSize="18"
                               TextWrapping="Wrap"
                               Margin="0,0,0,10"/>

                    <TextBlock x:Name="TxtNewsDate"
                               Foreground="#FFE0B84A"
                               FontSize="13"
                               Margin="0,0,0,10"/>

                    <TextBlock x:Name="TxtNewsSummary"
                               Foreground="White"
                               FontSize="14"
                               TextWrapping="Wrap"
                               Margin="0,0,0,16"
                               MaxHeight="52"/>

                    <DockPanel LastChildFill="False">
                        <TextBlock Text="Read More →"
                                   Foreground="#FFF2B300"
                                   FontWeight="Bold"
                                   FontSize="13"
                                   DockPanel.Dock="Left"/>

                        <TextBlock x:Name="TxtNewsIndex"
                                   Foreground="#FFBBBBBB"
                                   FontSize="12"
                                   DockPanel.Dock="Right"/>
                    </DockPanel>
                </StackPanel>
            </Grid>
        </Border>

        <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    Margin="20,395,0,0">
            <Button x:Name="BtnPrevNews"
                    Content="◀"
                    Width="34"
                    Height="26"
                    Margin="0,0,6,0"
                    Click="BtnPrevNews_Click"
                    Background="#AA222222"
                    Foreground="White"/>

            <Button x:Name="BtnNextNews"
                    Content="▶"
                    Width="34"
                    Height="26"
                    Click="BtnNextNews_Click"
                    Background="#AA222222"
                    Foreground="White"/>
        </StackPanel>

        <Grid VerticalAlignment="Bottom"
              Height="80"
              Background="#FF2D2D30">

            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        Margin="20,0,0,0">
                <Button Content="Facebook"
                        Width="70"
                        Height="30"
                        Margin="0,0,10,0"
                        Click="BtnSocial_Click"
                        Tag="https://www.facebook.com/yourpage"/>

                <Button Content="Discord"
                        Width="70"
                        Height="30"
                        Margin="0,0,10,0"
                        Click="BtnSocial_Click"
                        Tag="https://discord.gg/yourserver"/>

                <Button Content="YouTube"
                        Width="70"
                        Height="30"
                        Margin="0,0,10,0"
                        Click="BtnSocial_Click"
                        Tag="https://youtube.com/yourchannel"/>

                <Button Content="Website"
                        Width="70"
                        Height="30"
                        Margin="0,0,10,0"
                        Click="BtnSocial_Click"
                        Tag="https://c9-hd.com/"/>
            </StackPanel>

            <StackPanel Orientation="Vertical"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                <TextBlock Name="TxtVersion"
                           Text="Version: ตรวจสอบ..."
                           Foreground="White"
                           HorizontalAlignment="Center"
                           FontSize="14"
                           Margin="0,0,0,5"/>

                <Grid>
                    <ProgressBar Name="UpdateProgressBar"
                                 Width="250"
                                 Height="15"
                                 Minimum="0"
                                 Maximum="100"
                                 Visibility="Hidden"/>
                    <TextBlock Name="TxtProgress"
                               Text="0%"
                               Foreground="Black"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               FontSize="10"
                               Visibility="Hidden"/>
                </Grid>
            </StackPanel>

            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Margin="0,0,20,0">
                <Button Name="BtnOption"
                        Content="Options"
                        Width="80"
                        Height="40"
                        Margin="0,0,10,0"
                        Click="BtnOption_Click"
                        Background="#FF555555"
                        Foreground="White"/>

                <Button Name="BtnRepair"
                        Content="Repair"
                        Width="80"
                        Height="40"
                        Margin="0,0,10,0"
                        Click="BtnRepair_Click"
                        Background="#FFD84315"
                        Foreground="White"/>

                <Button Name="BtnStart"
                        Content="START GAME"
                        Width="120"
                        Height="40"
                        Click="BtnStart_Click"
                        Background="#FF007ACC"
                        Foreground="White"
                        FontWeight="Bold"
                        FontSize="14"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>